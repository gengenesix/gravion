#!/usr/bin/env bash
# GRAVION CLI — Military Intelligence Platform Control Tool
set -euo pipefail

GRAVION_DIR="${GRAVION_DIR:-/opt/gravion}"
BACKUP_DIR="/var/backups/gravion"
COMPOSE_FILE="$GRAVION_DIR/docker-compose.yml"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; BOLD='\033[1m'; NC='\033[0m'

# Fallback: run from script location if GRAVION_DIR doesn't exist
if [[ ! -d "$GRAVION_DIR" ]]; then
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  GRAVION_DIR="$(dirname "$SCRIPT_DIR")"
  COMPOSE_FILE="$GRAVION_DIR/docker-compose.yml"
fi

info()  { echo -e "${GREEN}[GRAVION]${NC} $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
err()   { echo -e "${RED}[ERROR]${NC} $*" >&2; exit 1; }
header(){ echo -e "${BLUE}${BOLD}$*${NC}"; }

require_compose() {
  [[ -f "$COMPOSE_FILE" ]] || err "docker-compose.yml not found at $COMPOSE_FILE"
}

# ─── Commands ─────────────────────────────────────────────────────────────────

cmd_start() {
  require_compose
  info "Starting GRAVION services..."
  cd "$GRAVION_DIR"
  docker compose up -d
  info "All services started. Run 'gravion status' to verify."
}

cmd_stop() {
  require_compose
  info "Stopping GRAVION services..."
  cd "$GRAVION_DIR"
  docker compose down
  info "All services stopped."
}

cmd_restart() {
  require_compose
  info "Restarting GRAVION services..."
  cd "$GRAVION_DIR"
  docker compose restart "$@"
  info "Services restarted."
}

cmd_status() {
  require_compose
  header "━━━ GRAVION Service Status ━━━"
  cd "$GRAVION_DIR"
  docker compose ps
  echo ""
  header "━━━ Port Bindings ━━━"
  docker compose ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || true
}

cmd_logs() {
  require_compose
  local service="${1:-}"
  cd "$GRAVION_DIR"
  if [[ -n "$service" ]]; then
    info "Tailing logs for service: $service"
    docker compose logs -f --tail=100 "$service"
  else
    info "Tailing all service logs (Ctrl+C to stop)"
    docker compose logs -f --tail=50
  fi
}

cmd_update() {
  require_compose
  info "Updating GRAVION..."
  cd "$GRAVION_DIR"

  # Pull latest code
  git pull --ff-only
  git submodule update --init --recursive

  # Rebuild and restart
  info "Rebuilding containers..."
  docker compose build --no-cache

  info "Restarting services..."
  docker compose up -d

  info "Update complete. Running version:"
  git log -1 --oneline
}

cmd_backup() {
  require_compose
  local timestamp
  timestamp=$(date +"%Y%m%d_%H%M%S")
  local backup_path="$BACKUP_DIR/gravion_backup_${timestamp}"

  mkdir -p "$backup_path"
  info "Creating backup at $backup_path..."

  cd "$GRAVION_DIR"

  # Backup Docker volumes
  info "Backing up Docker volumes..."
  local volumes
  volumes=$(docker compose config --volumes 2>/dev/null || true)

  if [[ -n "$volumes" ]]; then
    while IFS= read -r vol; do
      [[ -z "$vol" ]] && continue
      local full_vol
      full_vol=$(docker volume ls --format '{{.Name}}' | grep "$vol" | head -1 || true)
      if [[ -n "$full_vol" ]]; then
        info "  Backing up volume: $full_vol"
        docker run --rm \
          -v "${full_vol}:/data:ro" \
          -v "${backup_path}:/backup" \
          alpine tar -czf "/backup/${full_vol}.tar.gz" -C /data . 2>/dev/null || warn "Could not backup $full_vol"
      fi
    done <<< "$volumes"
  fi

  # Backup .env
  [[ -f "$GRAVION_DIR/server/.env" ]] && cp "$GRAVION_DIR/server/.env" "$backup_path/.env.bak"

  # Create manifest
  git -C "$GRAVION_DIR" log -1 --oneline > "$backup_path/MANIFEST.txt"
  date >> "$backup_path/MANIFEST.txt"

  # Compress entire backup
  tar -czf "${backup_path}.tar.gz" -C "$BACKUP_DIR" "gravion_backup_${timestamp}"
  rm -rf "$backup_path"

  info "Backup complete: ${backup_path}.tar.gz"
}

cmd_restore() {
  local backup_file="${1:-}"
  [[ -z "$backup_file" ]] && err "Usage: gravion restore <backup_file.tar.gz>"
  [[ -f "$backup_file" ]] || err "Backup file not found: $backup_file"

  warn "This will restore GRAVION from backup. Existing data may be overwritten."
  read -rp "Continue? [y/N] " confirm
  [[ "$confirm" =~ ^[Yy]$ ]] || { info "Restore cancelled."; exit 0; }

  local restore_dir
  restore_dir=$(mktemp -d)
  info "Extracting backup..."
  tar -xzf "$backup_file" -C "$restore_dir"

  local backup_dir
  backup_dir=$(find "$restore_dir" -maxdepth 1 -type d | tail -1)

  # Restore volumes
  info "Restoring Docker volumes..."
  for tar_file in "$backup_dir"/*.tar.gz; do
    [[ -f "$tar_file" ]] || continue
    local vol_name
    vol_name=$(basename "$tar_file" .tar.gz)
    info "  Restoring volume: $vol_name"
    docker volume create "$vol_name" 2>/dev/null || true
    docker run --rm \
      -v "${vol_name}:/data" \
      -v "${backup_dir}:/backup:ro" \
      alpine sh -c "rm -rf /data/* && tar -xzf /backup/$(basename "$tar_file") -C /data"
  done

  # Restore .env
  if [[ -f "$backup_dir/.env.bak" ]]; then
    cp "$backup_dir/.env.bak" "$GRAVION_DIR/server/.env"
    info "Restored .env"
  fi

  rm -rf "$restore_dir"
  info "Restore complete. Run 'gravion start' to restart services."
}

cmd_health() {
  require_compose
  header "━━━ GRAVION Health Check ━━━"
  cd "$GRAVION_DIR"

  local all_healthy=true

  check_service() {
    local name="$1"
    local url="$2"
    local expected="${3:-200}"
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 3 --max-time 5 "$url" 2>/dev/null || echo "000")
    if [[ "$code" == "$expected" || ( "$expected" == "200" && "$code" =~ ^2 ) ]]; then
      echo -e "  ${GREEN}✓${NC} ${name}: ${GREEN}OK${NC} (HTTP $code)"
    else
      echo -e "  ${RED}✗${NC} ${name}: ${RED}UNREACHABLE${NC} (HTTP $code)"
      all_healthy=false
    fi
  }

  echo "Checking services..."
  check_service "GRAVION Server"  "http://localhost:3001/health"
  check_service "GRAVION Client"  "http://localhost:3000"
  check_service "Neo4j HTTP"      "http://localhost:7474"
  check_service "Traccar"         "http://localhost:8082"
  check_service "Ollama"          "http://localhost:11434"
  check_service "Nginx"           "http://localhost:80"

  echo ""
  header "━━━ Container Status ━━━"
  docker compose ps --format "table {{.Name}}\t{{.Status}}" 2>/dev/null || true

  echo ""
  if $all_healthy; then
    echo -e "${GREEN}All services healthy.${NC}"
  else
    echo -e "${YELLOW}Some services are not responding. Check logs with: gravion logs <service>${NC}"
  fi
}

cmd_ip_trace() {
  local ip="${1:-}"
  [[ -z "$ip" ]] && err "Usage: gravion ip-trace <IP>"

  info "Tracing IP: $ip"
  local result
  result=$(curl -sf --max-time 10 "https://ipinfo.io/${ip}/json" 2>/dev/null) || err "Could not reach ipinfo.io — check network connection."

  echo ""
  header "━━━ IP Trace: $ip ━━━"
  echo "$result" | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    fields = [('ip','IP'),('hostname','Hostname'),('city','City'),('region','Region'),
              ('country','Country'),('org','Organization'),('loc','Coordinates'),
              ('timezone','Timezone'),('postal','Postal')]
    for key, label in fields:
        if key in d:
            print(f'  {label:<16}: {d[key]}')
    if 'loc' in d:
        lat, lon = d['loc'].split(',')
        print(f'  {\"Latitude\":<16}: {lat}')
        print(f'  {\"Longitude\":<16}: {lon}')
except Exception as e:
    print(sys.stdin.read())
" 2>/dev/null || echo "$result"
  echo ""
}

cmd_intel_brief() {
  local query="${*:-Generate current SITREP based on active intelligence feeds}"
  local api_url="http://localhost:3001/api/intel/sitrep"

  info "Querying GRAVION AI agent..."
  echo ""

  # Build JSON payload safely using python3
  local result
  result=$(python3 -c "
import urllib.request, urllib.error, json, sys
query = sys.argv[1]
payload = json.dumps({'query': query}).encode()
req = urllib.request.Request('$api_url', data=payload, headers={'Content-Type': 'application/json'})
try:
    with urllib.request.urlopen(req, timeout=60) as r:
        print(r.read().decode())
except Exception as e:
    print(json.dumps({'error': str(e)}))
" "$query" 2>/dev/null)

  if echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); exit(0 if 'sitrep' in d else 1)" 2>/dev/null; then
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BOLD}GRAVION SITREP — $(date -u '+%Y-%m-%d %H:%M:%S UTC')${NC}"
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    python3 -c "import sys,json; print(json.loads(sys.argv[1])['sitrep'])" "$result"
    echo ""
  else
    warn "AI agent unavailable or returned error:"
    echo "$result"
  fi
}

cmd_help() {
  echo ""
  echo -e "${BLUE}${BOLD}GRAVION CLI — Military Intelligence Platform${NC}"
  echo ""
  echo "Usage: gravion <command> [options]"
  echo ""
  echo -e "${BOLD}Commands:${NC}"
  echo "  start                Start all GRAVION services (docker compose up -d)"
  echo "  stop                 Stop all services (docker compose down)"
  echo "  restart [service]    Restart all or a specific service"
  echo "  status               Show running containers and port bindings"
  echo "  logs [service]       Tail logs (all services or a specific one)"
  echo "  update               Git pull + rebuild + restart"
  echo "  backup               Backup volumes to $BACKUP_DIR"
  echo "  restore <file>       Restore from a backup archive"
  echo "  health               Ping all services and report status"
  echo "  ip-trace <IP>        Geolocate and trace an IP address"
  echo "  intel-brief [query]  Generate AI SITREP via Ollama"
  echo "  help                 Show this help message"
  echo ""
  echo -e "${BOLD}Examples:${NC}"
  echo "  gravion start"
  echo "  gravion logs gravion-app"
  echo "  gravion restart ollama"
  echo "  gravion backup"
  echo "  gravion ip-trace 8.8.8.8"
  echo "  gravion intel-brief 'Show vessels near Strait of Hormuz'"
  echo "  gravion restore /var/backups/gravion/gravion_backup_20260101_120000.tar.gz"
  echo ""
}

# ─── Dispatch ─────────────────────────────────────────────────────────────────
case "${1:-help}" in
  start)    cmd_start ;;
  stop)     cmd_stop ;;
  restart)  shift; cmd_restart "$@" ;;
  status)   cmd_status ;;
  logs)     shift; cmd_logs "${1:-}" ;;
  update)   cmd_update ;;
  backup)   cmd_backup ;;
  restore)  shift; cmd_restore "${1:-}" ;;
  health)   cmd_health ;;
  ip-trace) shift; cmd_ip_trace "${1:-}" ;;
  intel-brief) shift; cmd_intel_brief "$@" ;;
  help|--help|-h) cmd_help ;;
  *) err "Unknown command: ${1}. Run 'gravion help' for usage." ;;
esac
