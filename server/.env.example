# ══════════════════════════════════════════════════════════
#  GRAVION Server — Environment Configuration
#  Copy to .env and fill in your values before starting.
# ══════════════════════════════════════════════════════════

# ─── Application ─────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Security ────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_32

# ─── CesiumJS Globe ──────────────────────────────────────
# Get from https://ion.cesium.com
CESIUM_ION_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJqdGkiOiJlYTM5YTUzZC0yNTkwLTQ5ZmEtOTRhMi01MTdiYjllOTFmNjQiLCJpZCI6NDA5MjE0LCJpYXQiOjE3NzQ0ODgzODN9.wp16tuCV8iKfcVyFD3jzJ52kgCB7uwbnWaCxlmAzeaQ

# ─── ADS-B Flight Data ───────────────────────────────────
FLIGHT_DATA_SOURCE=adsblol
ADSB_LOL_LAT=0
ADSB_LOL_LON=0
ADSB_LOL_RADIUS=25000

# ─── AIS Maritime Data ───────────────────────────────────
# Get from https://aisstream.io
AIS_API_KEY=9b03450186de3b3eeb0d28bdb684f3ad0bb1247f
AISSTREAM_API_KEY=9b03450186de3b3eeb0d28bdb684f3ad0bb1247f

# ─── Graph Database (Neo4j) ──────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=gravion_neo4j

# ─── Asset Tracking (Traccar) ────────────────────────────
TRACCAR_URL=http://localhost:8082
TRACCAR_USER=admin
TRACCAR_PASSWORD=gravion_traccar

# ─── AI / LLM (Ollama) ───────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── OSINT / LLM API ─────────────────────────────────────
# Get from https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── Cloudflare Radar API ────────────────────────────────
# Get from https://dash.cloudflare.com/
CLOUDFLARE_RADAR_TOKEN=your_cloudflare_token_here

# ─── OpenSky Network (optional) ──────────────────────────
# OPENSKY_CLIENT_ID=your_opensky_email@example.com
# OPENSKY_CLIENT_SECRET=your_opensky_secret_here
