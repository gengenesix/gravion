# Flight Data APIs
# OPENSKY_CLIENT_ID=your_opensky_email@example.com
# OPENSKY_CLIENT_SECRET=your_opensky_secret_here

FLIGHT_DATA_SOURCE=adsblol
ADSB_LOL_LAT=0
ADSB_LOL_LON=0
ADSB_LOL_RADIUS=25000

# Maritime Data API
# Get your free API key at https://aisstream.io
AISSTREAM_API_KEY=your_aisstream_api_key_here

# OSINT / LLM API
# Get from https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Cloudflare Radar API
# Get from https://dash.cloudflare.com/
CLOUDFLARE_RADAR_TOKEN=your_cloudflare_token_here
